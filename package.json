{
  "name": "openmaic-mcp",
  "version": "0.1.0",
  "description": "MCP server for OpenMAIC (open.maic.chat) — generate AI-powered interactive classrooms from any MCP client",
  "license": "AGPL-3.0",
  "type": "module",
  "bin": {
    "openmaic-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openmaic",
    "education",
    "ai-classroom"
  ]
}
